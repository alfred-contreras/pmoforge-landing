---
import Base from '../layouts/Base.astro';
import NavBar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Solution from '../components/Solution.astro';
import Audience from '../components/Audience.astro';
import ValueProp from '../components/ValueProp.astro';
import Competitive from '../components/Competitive.astro';
import Security from '../components/Security.astro';
import UseCases from '../components/UseCases.astro';
import UIPreview from '../components/UIPreview.astro';
import Vision from '../components/Vision.astro';
import Founder from '../components/Founder.astro';
import Waitlist from '../components/Waitlist.astro';
import Footer from '../components/Footer.astro';
import Reveal from '../components/Reveal.tsx';
import { getContent } from '../data/content';

const lang = 'es' as const;
const t = getContent(lang).meta;
---

<Base title={t.title} description={t.description} lang={lang}>
  <NavBar lang={lang} />
  <main id="main">
    <Reveal client:load y={48} duration={1.0}>
      <Hero lang={lang} />
    </Reveal>
    <Reveal client:load y={40}>
      <Problem lang={lang} />
    </Reveal>
    <Reveal client:load y={40}>
      <Solution lang={lang} />
    </Reveal>
    <Reveal client:load y={40}>
      <Audience lang={lang} />
    </Reveal>
    <Reveal client:load y={40}>
      <ValueProp lang={lang} />
    </Reveal>
    <Reveal client:load y={40}>
      <Competitive lang={lang} />
    </Reveal>
    <Reveal client:load y={40}>
      <Security lang={lang} />
    </Reveal>
    <Reveal client:load y={40}>
      <UseCases lang={lang} />
    </Reveal>
    <Reveal client:load y={40}>
      <UIPreview lang={lang} />
    </Reveal>
    <Reveal client:load y={40}>
      <Vision lang={lang} />
    </Reveal>
    <Reveal client:load y={36}>
      <Founder lang={lang} />
    </Reveal>
    <Reveal client:load y={36}>
      <Waitlist lang={lang} />
    </Reveal>
  </main>
  <Footer lang={lang} />
</Base>
