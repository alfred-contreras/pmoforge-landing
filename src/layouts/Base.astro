---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import SmoothScroll from '../components/SmoothScroll.astro';

interface Props {
  title: string;
  description: string;
  lang: 'es' | 'en';
}

const { title, description, lang } = Astro.props;

const SITE = 'https://pmoforge-landing.vercel.app';
const OG_IMAGE = lang === 'en' ? `${SITE}/og-en.png` : `${SITE}/og.png`;
const canonical = lang === 'en' ? `${SITE}/en/` : `${SITE}/`;

// Autoría y fechas de publicación.
// AUTHOR: nombre del fundador (mismo para ambos idiomas).
// PUBLISHED_ISO: fecha del primer release público de la landing (no cambia).
// MODIFIED_ISO: fecha del último release relevante. Sincronizar con CHANGELOG.md
//   al cerrar cada versión (formato ISO 8601 con "Z" para UTC).
const AUTHOR = 'Alfredo Contreras';
const PUBLISHED_ISO = '2026-05-01T00:00:00Z';
const MODIFIED_ISO = '2026-05-22T00:00:00Z';

const OG_IMAGE_ALT = lang === 'en'
  ? 'PMOforge — agentic PMO with multi-agent coordination over a shared board'
  : 'PMOforge — PMO agéntica con coordinación multi-agente sobre tablero compartido';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={AUTHOR} />
    <meta name="theme-color" content="#FF7A1A" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="627" />
    <meta property="og:image:alt" content={OG_IMAGE_ALT} />
    <meta property="article:author" content={AUTHOR} />
    <meta property="article:published_time" content={PUBLISHED_ISO} />
    <meta property="article:modified_time" content={MODIFIED_ISO} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta name="twitter:image:alt" content={OG_IMAGE_ALT} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <Analytics />
    <SpeedInsights />
  </head>
  <body class="min-h-screen">
    <a href="#main"
       class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-ink-900 text-white px-3 py-1.5 rounded-md z-50">
      {lang === 'en' ? 'Skip to content' : 'Saltar al contenido'}
    </a>
    <slot />
    <SmoothScroll />
  </body>
</html>
