---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SmoothScroll from '../components/SmoothScroll.astro';

interface Props {
  title: string;
  description: string;
  lang: 'es' | 'en';
}

const { title, description, lang } = Astro.props;

const SITE = 'https://pmoforge-landing.vercel.app';
const OG_IMAGE = lang === 'en' ? `${SITE}/og-en.png` : `${SITE}/og.png`;
const canonical = lang === 'en' ? `${SITE}/en/` : `${SITE}/`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FF7A1A" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="627" />
    <meta property="og:image:alt" content="PMOforge — hierarchical AI agents for Agile PMOs" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={OG_IMAGE} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <Analytics />
  </head>
  <body class="min-h-screen">
    <a href="#main"
       class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-ink-900 text-white px-3 py-1.5 rounded-md z-50">
      {lang === 'en' ? 'Skip to content' : 'Saltar al contenido'}
    </a>
    <slot />
    <SmoothScroll />
  </body>
</html>
