---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).valueProp;
---

<section id="value" class="relative">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 max-w-3xl leading-tight">
      {t.title}
    </h2>
    <p class="mt-5 text-lg text-ink-700 max-w-3xl leading-relaxed">{t.lead}</p>

    <div class="mt-12 grid md:grid-cols-2 gap-5">
      {t.pillars.map((pillar) => (
        <article class="card flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <span
              class="inline-grid place-items-center w-11 h-11 rounded-xl bg-ink-900 text-ember-300 font-serif font-bold text-xl"
              aria-hidden="true"
            >
              {pillar.icon}
            </span>
            <span class="text-xs font-semibold uppercase tracking-wider text-ember-700">
              {pillar.label}
            </span>
          </div>
          <h3 class="font-serif font-bold text-xl text-ink-900 leading-snug">
            {pillar.title}
          </h3>
          <p class="text-ink-900 font-medium leading-snug">{pillar.claim}</p>
          <p class="text-ink-700 leading-relaxed">{pillar.body}</p>
        </article>
      ))}
    </div>

    <p class="mt-10 max-w-3xl text-ink-700 leading-relaxed italic border-l-2 border-ember-500 pl-4">
      {t.closer}
    </p>
  </div>
</section>
