---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).valueProp;
---

<section id="value" class="relative">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 max-w-3xl leading-tight">
      {t.title}
    </h2>
    <p class="mt-5 text-lg text-ink-700 max-w-3xl leading-relaxed">{t.lead}</p>

    <div class="mt-12 grid md:grid-cols-2 gap-5">
      {t.pillars.map((pillar) => (
        <article class="card flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <span
              class="inline-grid place-items-center w-12 h-12 rounded-xl bg-ink-900 text-ember-200 shadow-sm"
              aria-hidden="true"
            >
              {pillar.iconKey === 'memory' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <ellipse cx="12" cy="5" rx="9" ry="3"/>
                  <path d="M3 5v6c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/>
                  <path d="M3 11v6c0 1.66 4.03 3 9 3s9-1.34 9-3v-6"/>
                </svg>
              )}
              {pillar.iconKey === 'audit' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2l3 2 3-1 1 3 3 1-1 3 1 3-3 1-1 3-3-1-3 2-3-2-3 1-1-3-3-1 1-3-1-3 3-1 1-3 3 1z"/>
                  <polyline points="8 12 11 15 16 9"/>
                </svg>
              )}
              {pillar.iconKey === 'evm' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 3v18h18"/>
                  <rect x="6" y="13" width="3" height="5"/>
                  <rect x="11" y="9" width="3" height="9"/>
                  <rect x="16" y="5" width="3" height="13"/>
                  <polyline points="3 14 8 10 13 12 21 5"/>
                </svg>
              )}
              {pillar.iconKey === 'resilience' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <polyline points="9 12 11 14 15 10"/>
                </svg>
              )}
            </span>
            <span class="text-xs font-semibold uppercase tracking-wider text-ember-700">
              {pillar.label}
            </span>
          </div>
          <h3 class="font-serif font-bold text-xl text-ink-900 leading-snug">
            {pillar.title}
          </h3>
          <p class="text-ink-900 font-medium leading-snug">{pillar.claim}</p>
          <p class="text-ink-700 leading-relaxed">{pillar.body}</p>
        </article>
      ))}
    </div>

    <p class="mt-10 max-w-3xl text-ink-700 leading-relaxed italic border-l-2 border-ember-500 pl-4">
      {t.closer}
    </p>
  </div>
</section>
