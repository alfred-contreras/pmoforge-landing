---
import type { Lang } from '../data/content';
import { getContent, calendlyUrl } from '../data/content';
import MagneticButton from './MagneticButton.tsx';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).hero;

const labels = {
  command:    lang === 'en' ? 'COMMAND'     : 'MANDO',
  supervision:lang === 'en' ? 'SUPERVISION' : 'SUPERVISIÓN',
  operational:lang === 'en' ? 'OPERATIONAL' : 'OPERATIVOS'
};
---

<section class="relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-5 pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-7">
        <span class="eyebrow">{t.eyebrow}</span>
        <h1 class="mt-4 text-4xl md:text-6xl font-bold leading-[1.05] text-ink-900">
          {t.title}
        </h1>
        <p class="mt-6 text-lg md:text-xl text-ink-700 max-w-2xl">
          {t.subtitle}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <MagneticButton client:load href="#waitlist" className="btn-primary">
            {t.ctaPrimary} →
          </MagneticButton>
          <MagneticButton client:load href={calendlyUrl} external strength={0.18} className="btn-ghost">
            {t.ctaSecondary}
          </MagneticButton>
        </div>
      </div>

      <!-- Ilustración: jerarquía de agentes con marcos por capa -->
      <div class="md:col-span-5">
        <div class="relative aspect-[460/420] max-w-md mx-auto">
          <svg viewBox="0 0 460 420" class="w-full h-full" aria-hidden="true">
            <defs>
              <linearGradient id="grad-ember" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#FF7A1A" />
                <stop offset="100%" stop-color="#B84507" />
              </linearGradient>
            </defs>

            <!-- ===== MARCO CAPA 1 — MANDO ===== -->
            <rect x="10" y="10" width="440" height="110" rx="14"
                  fill="rgba(255,246,229,0.35)" stroke="#E8EDF3"
                  stroke-width="1.5" stroke-dasharray="5 4" />
            <text x="22" y="30" fill="#56657A" font-size="11" font-weight="700"
                  letter-spacing="1.2">{labels.command}</text>
            <circle cx="230" cy="72" r="32" fill="url(#grad-ember)" />
            <text x="230" y="77" text-anchor="middle" fill="white"
                  font-size="13" font-weight="700">PMP</text>

            <!-- Conexión Mando -> Supervisión -->
            <line x1="230" y1="104" x2="230" y2="158" stroke="#CCD5E0" stroke-width="2" />

            <!-- ===== MARCO CAPA 2 — SUPERVISIÓN ===== -->
            <rect x="10" y="135" width="440" height="100" rx="14"
                  fill="rgba(255,201,122,0.10)" stroke="#FFC97A"
                  stroke-width="1.5" stroke-dasharray="5 4" />
            <text x="22" y="155" fill="#B84507" font-size="11" font-weight="700"
                  letter-spacing="1.2">{labels.supervision}</text>
            <rect x="180" y="173" width="100" height="44" rx="10" fill="#243044" />
            <text x="230" y="201" text-anchor="middle" fill="#FFC97A"
                  font-size="13" font-weight="700">Supervisor</text>

            <!-- Conexiones Supervisión -> Operativos -->
            <line x1="200" y1="217" x2="80"  y2="335" stroke="#CCD5E0" stroke-width="1.5" />
            <line x1="220" y1="217" x2="170" y2="335" stroke="#CCD5E0" stroke-width="1.5" />
            <line x1="240" y1="217" x2="290" y2="335" stroke="#CCD5E0" stroke-width="1.5" />
            <line x1="260" y1="217" x2="380" y2="335" stroke="#CCD5E0" stroke-width="1.5" />

            <!-- ===== MARCO CAPA 3 — OPERATIVOS ===== -->
            <rect x="10" y="265" width="440" height="145" rx="14"
                  fill="rgba(232,237,243,0.25)" stroke="#E8EDF3"
                  stroke-width="1.5" stroke-dasharray="5 4" />
            <text x="22" y="285" fill="#56657A" font-size="11" font-weight="700"
                  letter-spacing="1.2">{labels.operational}</text>

            <!-- Agentes operativos -->
            <g>
              <circle cx="80"  cy="350" r="28" fill="white" stroke="#FFA63D" stroke-width="2" />
              <text x="80" y="354" text-anchor="middle" fill="#243044"
                    font-size="11" font-weight="700">RAID</text>
            </g>
            <g>
              <circle cx="170" cy="350" r="28" fill="white" stroke="#FFA63D" stroke-width="2" />
              <text x="170" y="354" text-anchor="middle" fill="#243044"
                    font-size="11" font-weight="700">Status</text>
            </g>
            <g>
              <circle cx="290" cy="350" r="28" fill="white" stroke="#FFA63D" stroke-width="2" />
              <text x="290" y="354" text-anchor="middle" fill="#243044"
                    font-size="11" font-weight="700">Minuta</text>
            </g>
            <g>
              <circle cx="380" cy="350" r="28" fill="white" stroke="#FFA63D" stroke-width="2" />
              <text x="380" y="354" text-anchor="middle" fill="#243044"
                    font-size="11" font-weight="700">Deps</text>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
