---
import type { Lang } from '../data/content';
import { getContent, calendlyUrl } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).hero;
---

<section class="relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-5 pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-7">
        <span class="eyebrow">{t.eyebrow}</span>
        <h1 class="mt-4 text-4xl md:text-6xl font-bold leading-[1.05] text-ink-900">
          {t.title}
        </h1>
        <p class="mt-6 text-lg md:text-xl text-ink-700 max-w-2xl">
          {t.subtitle}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#waitlist" class="btn-primary">{t.ctaPrimary} →</a>
          <a href={calendlyUrl} target="_blank" rel="noopener" class="btn-ghost">{t.ctaSecondary}</a>
        </div>
      </div>

      <!-- Ilustración: jerarquía de agentes -->
      <div class="md:col-span-5">
        <div class="relative aspect-square max-w-md mx-auto">
          <svg viewBox="0 0 400 400" class="w-full h-full" aria-hidden="true">
            <defs>
              <linearGradient id="grad-ember" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#FF7A1A" />
                <stop offset="100%" stop-color="#B84507" />
              </linearGradient>
            </defs>

            <!-- Capa Mando (PMP humano) -->
            <circle cx="200" cy="60" r="36" fill="url(#grad-ember)" />
            <text x="200" y="65" text-anchor="middle" fill="white" font-size="13" font-weight="700">PMP</text>

            <!-- Conexiones a supervisor -->
            <line x1="200" y1="96" x2="200" y2="160" stroke="#CCD5E0" stroke-width="2" />

            <!-- Capa Supervisión -->
            <rect x="150" y="160" width="100" height="48" rx="12" fill="#243044" />
            <text x="200" y="190" text-anchor="middle" fill="#FFC97A" font-size="12" font-weight="600">Supervisor</text>

            <!-- Conexiones a operativos -->
            <line x1="160" y1="208" x2="80"  y2="290" stroke="#CCD5E0" stroke-width="2" />
            <line x1="190" y1="208" x2="160" y2="290" stroke="#CCD5E0" stroke-width="2" />
            <line x1="210" y1="208" x2="240" y2="290" stroke="#CCD5E0" stroke-width="2" />
            <line x1="240" y1="208" x2="320" y2="290" stroke="#CCD5E0" stroke-width="2" />

            <!-- Agentes operativos -->
            <g>
              <circle cx="80"  cy="310" r="28" fill="white" stroke="#FFA63D" stroke-width="2" />
              <text x="80" y="314" text-anchor="middle" fill="#243044" font-size="10" font-weight="700">RAID</text>
            </g>
            <g>
              <circle cx="160" cy="310" r="28" fill="white" stroke="#FFA63D" stroke-width="2" />
              <text x="160" y="314" text-anchor="middle" fill="#243044" font-size="10" font-weight="700">Status</text>
            </g>
            <g>
              <circle cx="240" cy="310" r="28" fill="white" stroke="#FFA63D" stroke-width="2" />
              <text x="240" y="314" text-anchor="middle" fill="#243044" font-size="10" font-weight="700">Minuta</text>
            </g>
            <g>
              <circle cx="320" cy="310" r="28" fill="white" stroke="#FFA63D" stroke-width="2" />
              <text x="320" y="314" text-anchor="middle" fill="#243044" font-size="10" font-weight="700">Deps</text>
            </g>

            <!-- Etiquetas de capas -->
            <text x="20" y="65" fill="#56657A" font-size="10" font-weight="600">{lang === 'en' ? 'Command' : 'Mando'}</text>
            <text x="20" y="190" fill="#56657A" font-size="10" font-weight="600">{lang === 'en' ? 'Supervision' : 'Supervisión'}</text>
            <text x="20" y="318" fill="#56657A" font-size="10" font-weight="600">{lang === 'en' ? 'Operational' : 'Operativos'}</text>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
