---
import type { Lang } from '../data/content';
import { getContent, calendlyUrl } from '../data/content';
import MagneticButton from './MagneticButton.tsx';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).hero;
const g = t.graph;
---

<section class="relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-5 pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-5">
        <span class="eyebrow">{t.eyebrow}</span>
        <h1 class="mt-4 text-4xl md:text-6xl font-bold leading-[1.05] text-ink-900">
          {t.title}
        </h1>
        <p class="mt-6 text-lg md:text-xl text-ink-700 max-w-2xl">
          {t.subtitle}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <MagneticButton client:load href="#waitlist" className="btn-primary">
            {t.ctaPrimary} →
          </MagneticButton>
          <MagneticButton client:load href={calendlyUrl} external strength={0.18} className="btn-ghost">
            {t.ctaSecondary}
          </MagneticButton>
        </div>
      </div>

      <!--
        Gráfica hero — "Constelación orbital"
        ====================================================================
        Tablero compartido al centro; 8 agentes operacionales en órbita;
        PM con burbuja al norte habla con Coordinador (puerta única);
        Dashboard ejecutivo al sur-oeste; Artefactos PMO al sur-este.
        Fundamento: slide 6 de session-02-deck.pptx v2.0 evolucionado para
        integrar outputs (Dashboard + Artefactos) que faltaban en el slide.
      -->
      <div class="md:col-span-7">
        <div class="relative aspect-[600/580] max-w-2xl mx-auto">
          <svg viewBox="0 0 600 580" class="w-full h-full" aria-hidden="true">
            <defs>
              <radialGradient id="hero-core" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#FFE6B8"/>
                <stop offset="60%" stop-color="#FFC97A"/>
                <stop offset="100%" stop-color="#FF7A1A"/>
              </radialGradient>
              <radialGradient id="hero-glow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#FF7A1A" stop-opacity=".35"/>
                <stop offset="100%" stop-color="#FF7A1A" stop-opacity="0"/>
              </radialGradient>
            </defs>

            <!-- PM y burbuja (norte) -->
            <circle cx="300" cy="50" r="24" fill="#243044"/>
            <text x="300" y="55" text-anchor="middle" fill="#FFC97A"
                  font-size="11" font-weight="700" font-family="Inter">PM</text>
            <path d="M 332 38 Q 360 28 405 32 L 470 32 Q 488 36 488 50 L 488 64 Q 488 78 470 80 L 360 80 Q 340 76 332 64 Z"
                  fill="white" stroke="#CCD5E0"/>
            <text x="410" y="58" text-anchor="middle" font-size="11" font-weight="600"
                  fill="#243044" font-family="Inter">
              {g.pmBubble}
            </text>
            <line x1="300" y1="78" x2="300" y2="115" stroke="#CCD5E0"/>

            <!-- Coordinador como puerta única -->
            <rect x="225" y="115" width="150" height="38" rx="10"
                  fill="url(#hero-core)" stroke="#B84507"/>
            <text x="300" y="139" text-anchor="middle" font-size="12"
                  font-weight="700" fill="#0B1525" font-family="Inter">
              {g.coordinator}
            </text>
            <line x1="300" y1="153" x2="300" y2="185" stroke="#CCD5E0"/>

            <!-- Halo del núcleo -->
            <circle cx="300" cy="310" r="180" fill="url(#hero-glow)"/>

            <!-- Tablero compartido (núcleo) -->
            <circle cx="300" cy="310" r="65" fill="url(#hero-core)"
                    stroke="#B84507" stroke-width="2"/>
            <text x="300" y="315" text-anchor="middle" font-size="12"
                  font-weight="700" fill="#0B1525" font-family="Inter">{g.board}</text>
            <text x="300" y="335" text-anchor="middle" font-size="9"
                  fill="#243044" font-family="Inter">{g.boardSub}</text>

            <!-- Anillo orbital -->
            <circle cx="300" cy="310" r="130" fill="none"
                    stroke="#FFC97A" stroke-dasharray="2 3" opacity=".7"/>

            <!-- 8 agentes en órbita (Auditor destacado en ember-100) -->
            <g font-family="Inter" font-size="9" font-weight="700" fill="#0B1525">
              <g><circle cx="300" cy="180" r="22" fill="#fff" stroke="#FFA63D" stroke-width="2"/>
                 <text x="300" y="183" text-anchor="middle">{g.agents.onboarder}</text></g>
              <g><circle cx="392" cy="218" r="22" fill="#fff" stroke="#FFA63D" stroke-width="2"/>
                 <text x="392" y="221" text-anchor="middle">{g.agents.scope}</text></g>
              <g><circle cx="430" cy="310" r="22" fill="#fff" stroke="#FFA63D" stroke-width="2"/>
                 <text x="430" y="313" text-anchor="middle">{g.agents.schedule}</text></g>
              <g><circle cx="392" cy="402" r="22" fill="#fff" stroke="#FFA63D" stroke-width="2"/>
                 <text x="392" y="405" text-anchor="middle">{g.agents.evm}</text></g>
              <g><circle cx="300" cy="440" r="22" fill="#fff" stroke="#FFA63D" stroke-width="2"/>
                 <text x="300" y="443" text-anchor="middle">{g.agents.risks}</text></g>
              <g><circle cx="208" cy="402" r="22" fill="#fff" stroke="#FFA63D" stroke-width="2"/>
                 <text x="208" y="405" text-anchor="middle">{g.agents.minutes}</text></g>
              <g><circle cx="170" cy="310" r="22" fill="#FFE6B8" stroke="#E55F0A" stroke-width="2"/>
                 <text x="170" y="313" text-anchor="middle">{g.agents.auditor}</text></g>
              <g><circle cx="208" cy="218" r="22" fill="#fff" stroke="#FFA63D" stroke-width="2"/>
                 <text x="208" y="221" text-anchor="middle">{g.agents.repo}</text></g>
            </g>

            <!-- Dashboard ejecutivo (sur-oeste) -->
            <rect x="20" y="480" width="240" height="90" rx="12" fill="#0B1525"/>
            <text x="32" y="500" font-size="9" font-weight="700" fill="#FFC97A"
                  letter-spacing="1" font-family="Inter">{g.dashboardLabel}</text>
            <rect x="32" y="508" width="60" height="52" rx="6" fill="#0d1b30" stroke="#243044"/>
            <text x="62" y="522" text-anchor="middle" fill="#FFC97A" font-size="8" font-family="Inter">CPI</text>
            <text x="62" y="544" text-anchor="middle" fill="#fff" font-size="14" font-weight="700" font-family="Inter">1.04</text>
            <rect x="100" y="508" width="60" height="52" rx="6" fill="#0d1b30" stroke="#243044"/>
            <text x="130" y="522" text-anchor="middle" fill="#FFC97A" font-size="8" font-family="Inter">SPI</text>
            <text x="130" y="544" text-anchor="middle" fill="#fff" font-size="14" font-weight="700" font-family="Inter">0.97</text>
            <rect x="168" y="508" width="84" height="52" rx="6" fill="#0d1b30" stroke="#243044"/>
            <text x="210" y="522" text-anchor="middle" fill="#FFC97A" font-size="8" font-family="Inter">EAC</text>
            <text x="210" y="544" text-anchor="middle" fill="#fff" font-size="12" font-weight="700" font-family="Inter">$1.2M</text>

            <!-- Artefactos PMO (sur-este) -->
            <rect x="290" y="480" width="290" height="90" rx="12"
                  fill="#fff" stroke="#FFC97A" stroke-dasharray="4 4"/>
            <text x="302" y="500" font-size="9" font-weight="700" fill="#B84507"
                  letter-spacing="1" font-family="Inter">{g.artifactsLabel}</text>
            <g font-family="Inter" font-size="9">
              <rect x="302" y="510" width="80" height="22" rx="5" fill="#FFF6E5" stroke="#FFC97A"/>
              <text x="342" y="525" text-anchor="middle" font-weight="700" fill="#243044">{g.artifacts.status}</text>
              <rect x="388" y="510" width="80" height="22" rx="5" fill="#FFF6E5" stroke="#FFC97A"/>
              <text x="428" y="525" text-anchor="middle" font-weight="700" fill="#243044">{g.artifacts.raid}</text>
              <rect x="474" y="510" width="98" height="22" rx="5" fill="#FFF6E5" stroke="#FFC97A"/>
              <text x="523" y="525" text-anchor="middle" font-weight="700" fill="#243044">{g.artifacts.minute}</text>
              <rect x="302" y="538" width="80" height="22" rx="5" fill="#FFF6E5" stroke="#FFC97A"/>
              <text x="342" y="553" text-anchor="middle" font-weight="700" fill="#243044">{g.artifacts.schedule}</text>
              <rect x="388" y="538" width="80" height="22" rx="5" fill="#FFF6E5" stroke="#FFC97A"/>
              <text x="428" y="553" text-anchor="middle" font-weight="700" fill="#243044">{g.artifacts.evm}</text>
              <rect x="474" y="538" width="98" height="22" rx="5" fill="#0B1525"/>
              <text x="523" y="553" text-anchor="middle" font-weight="700" fill="#FFC97A">{g.artifacts.committee}</text>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
