---
import type { Lang } from '../data/content';
import { getContent, calendlyUrl } from '../data/content';
import MagneticButton from './MagneticButton.tsx';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).hero;
const g = t.graph;

// 8 agentes — posiciones definidas en CSS por su key
const agents = [
  { key: 'onboarder', name: g.agents.onboarder, highlight: false },
  { key: 'scope',     name: g.agents.scope,     highlight: false },
  { key: 'schedule',  name: g.agents.schedule,  highlight: false },
  { key: 'repo',      name: g.agents.repo,      highlight: false },
  { key: 'evm',       name: g.agents.evm,       highlight: false },
  { key: 'minutes',   name: g.agents.minutes,   highlight: false },
  { key: 'risks',     name: g.agents.risks,     highlight: false },
  { key: 'auditor',   name: g.agents.auditor,   highlight: true  },
];

// Roles humanos (lista para Capa 1)
const rolesLabel = lang === 'en' ? 'Human roles' : 'Roles humanos';
const rolesList  = 'PM · ' + (lang === 'en' ? 'PMO Director · CTO · CEO' : 'Director PMO · CTO · CEO');
const platformAriaLabel = lang === 'en' ? 'Multi-agent operational platform' : 'Plataforma operativa multiagente';
---

<section class="relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-5 pt-16 pb-16 md:pt-24 md:pb-24">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">

      <!-- LEFT: copy -->
      <div class="lg:col-span-5">
        <span class="eyebrow">{t.eyebrow}</span>
        <h1 class="mt-4 text-4xl md:text-6xl font-bold leading-[1.05] text-ink-900">
          {t.title}
        </h1>
        <p class="mt-6 text-lg md:text-xl text-ink-700 max-w-2xl">
          {t.subtitle}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <MagneticButton client:load href="#waitlist" className="btn-primary">
            {t.ctaPrimary} →
          </MagneticButton>
          <MagneticButton client:load href={calendlyUrl} external strength={0.18} className="btn-ghost">
            {t.ctaSecondary}
          </MagneticButton>
        </div>
      </div>

      <!-- RIGHT: Arquitectura isométrica 2.5D -->
      <div class="lg:col-span-7">
        <div class="iso-wrap" role="img" aria-label={platformAriaLabel}>
          <div class="iso-scene">
            <div class="iso-stage">

              <!-- =====================================================
                   CAPA 1 — Interfaz y roles (translateZ +120)
                   ===================================================== -->
              <div class="iso-layer iso-l1">
                <article class="iso-card iso-roles-card">
                  <div class="iso-row">
                    <div class="iso-avatar" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="28" height="28" fill="none"
                           stroke="currentColor" stroke-width="1.8"
                           stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="8" r="4"/>
                        <path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
                        <path d="M11.2 14l.8 3.2L12.8 14" fill="currentColor" stroke="none"/>
                      </svg>
                    </div>

                    <div class="iso-roles-text">
                      <span class="iso-tag">{rolesLabel}</span>
                      <div class="iso-roles-list">{rolesList}</div>
                    </div>

                    <div class="iso-conn" aria-hidden="true">
                      <svg viewBox="0 0 32 16" width="32" height="16" fill="none"
                           stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                        <line x1="2" y1="8" x2="26" y2="8" stroke-dasharray="3 3"/>
                        <polyline points="22,3 28,8 22,13"/>
                      </svg>
                    </div>

                    <div class="iso-coord-card" aria-label={g.coordinator}>
                      <div class="iso-coord-name">{g.coordinator}</div>
                      <div class="iso-coord-sub">{g.coordinatorRole}</div>
                    </div>
                  </div>
                  <p class="iso-desc">{g.pmBubbleLine2}</p>
                </article>
              </div>

              <!-- =====================================================
                   CAPA 2 — Capa operativa multiagente (translateZ 0)
                   ===================================================== -->
              <div class="iso-layer iso-l2">
                <div class="iso-platform">
                  <span class="iso-platform-tag">{g.layerLabel}</span>

                  <div class="iso-platform-inner">

                    <!-- SVG: flechas bidireccionales agente ↔ tablero -->
                    <svg class="iso-arrows" viewBox="0 0 600 400"
                         preserveAspectRatio="none" aria-hidden="true">
                      <defs>
                        <marker id="iso-arrEnd" viewBox="0 0 10 10"
                                refX="9" refY="5" markerWidth="5.5" markerHeight="5.5"
                                orient="auto">
                          <path d="M0 0L10 5L0 10z" fill="#FFC97A"/>
                        </marker>
                        <marker id="iso-arrStart" viewBox="0 0 10 10"
                                refX="1" refY="5" markerWidth="5.5" markerHeight="5.5"
                                orient="auto-start-reverse">
                          <path d="M0 0L10 5L0 10z" fill="#FFC97A"/>
                        </marker>
                      </defs>
                      <g stroke="#FFA63D" stroke-width="1.3" stroke-dasharray="4 3"
                         fill="none"
                         marker-start="url(#iso-arrStart)" marker-end="url(#iso-arrEnd)">
                        <!-- Onboarder ↔ hex top-left -->
                        <line x1="120" y1="58"  x2="260" y2="155"/>
                        <!-- Scope (N) ↔ hex top -->
                        <line x1="300" y1="58"  x2="300" y2="140"/>
                        <!-- Schedule ↔ hex top-right -->
                        <line x1="480" y1="58"  x2="340" y2="155"/>
                        <!-- Repo (W) ↔ hex left -->
                        <line x1="110" y1="200" x2="248" y2="200"/>
                        <!-- EVM (E) ↔ hex right -->
                        <line x1="490" y1="200" x2="352" y2="200"/>
                        <!-- Minutes ↔ hex bot-left -->
                        <line x1="120" y1="342" x2="260" y2="245"/>
                        <!-- Risks (S) ↔ hex bottom -->
                        <line x1="300" y1="342" x2="300" y2="260"/>
                        <!-- Auditor ↔ hex bot-right -->
                        <line x1="480" y1="342" x2="340" y2="245"/>
                      </g>
                    </svg>

                    <!-- 8 agentes -->
                    {agents.map((a) => (
                      <div class={`iso-agent iso-agent-${a.key}${a.highlight ? ' iso-agent-hl' : ''}`}>
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <rect x="4" y="6" width="16" height="12" rx="2"/>
                          <line x1="8"  y1="11" x2="10" y2="11" stroke-width="2.5"/>
                          <line x1="14" y1="11" x2="16" y2="11" stroke-width="2.5"/>
                          <line x1="9"  y1="15" x2="15" y2="15"/>
                          <line x1="2"  y1="11" x2="4"  y2="11"/>
                          <line x1="20" y1="11" x2="22" y2="11"/>
                        </svg>
                        <span>{a.name}</span>
                      </div>
                    ))}

                    <!-- Hexágono central — Tablero compartido -->
                    <div class="iso-hex" aria-label={g.board}>
                      <div class="iso-hex-inner">
                        <span class="iso-hex-name">{g.board}</span>
                        <span class="iso-hex-sub">{g.boardSub}</span>
                      </div>
                    </div>

                  </div>
                </div>
              </div>

              <!-- =====================================================
                   CAPA 3 — Datos, artefactos y analítica (translateZ -120)
                   ===================================================== -->
              <div class="iso-layer iso-l3">
                <div class="iso-l3-grid">

                  <article class="iso-card iso-dashboard">
                    <span class="iso-tag iso-tag-amber">{g.dashboardLabel}</span>
                    <div class="iso-kpis">
                      <div class="iso-kpi">
                        <span class="k">CPI</span><span class="v">1.04</span>
                        <span class="d">↑ saludable</span>
                      </div>
                      <div class="iso-kpi">
                        <span class="k">SPI</span><span class="v">0.97</span>
                        <span class="d">≈ a tiempo</span>
                      </div>
                      <div class="iso-kpi">
                        <span class="k">EAC</span><span class="v">$1.2M</span>
                        <span class="d">+3% baseline</span>
                      </div>
                    </div>
                  </article>

                  <article class="iso-card iso-artifacts">
                    <span class="iso-tag iso-tag-amber">{g.artifactsLabel}</span>
                    <div class="iso-art-grid">
                      <span class="iso-art">{g.artifacts.status}</span>
                      <span class="iso-art">{g.artifacts.raid}</span>
                      <span class="iso-art">{g.artifacts.minute}</span>
                      <span class="iso-art">{g.artifacts.schedule}</span>
                      <span class="iso-art">{g.artifacts.evm}</span>
                      <span class="iso-art iso-art-cta">{g.artifacts.committee}</span>
                    </div>
                  </article>

                </div>
              </div>

            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ============================================================
     Arquitectura isométrica 2.5D — Hero
     Variables CSS para mantener tweakable los valores 3D
     ============================================================ */
  .iso-wrap {
    --iso-bg-1: #0B0F19;
    --iso-bg-2: #131A2C;
    --iso-glass:        rgba(255, 255, 255, 0.05);
    --iso-glass-strong: rgba(255, 255, 255, 0.09);
    --iso-glass-border: rgba(255, 255, 255, 0.10);
    --iso-amber-50:  #FFF6E5;
    --iso-amber-200: #FFC97A;
    --iso-amber-300: #FFB35A;
    --iso-amber-400: #FFA63D;
    --iso-amber-500: #FF7A1A;
    --iso-amber-600: #E55F0A;
    --iso-tilt-x: 60deg;
    --iso-tilt-z: -45deg;
    --iso-elev:   120px;
    --iso-duration: 500ms;

    position: relative;
    border-radius: 24px;
    padding: 36px 28px;
    overflow: hidden;
    background:
      radial-gradient(48% 40% at 22% 28%, rgba(255, 122, 26, 0.18), transparent 60%),
      radial-gradient(34% 34% at 78% 72%, rgba(255, 201, 122, 0.12), transparent 60%),
      linear-gradient(140deg, var(--iso-bg-1) 0%, var(--iso-bg-2) 100%);
    box-shadow:
      0 30px 60px -30px rgba(11, 21, 37, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    min-height: 600px;
  }

  /* Grid sutil de fondo (estilo blueprint) */
  .iso-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 36px 36px;
    pointer-events: none;
    mask-image: radial-gradient(60% 50% at 50% 45%, #000 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(60% 50% at 50% 45%, #000 30%, transparent 100%);
  }

  .iso-scene {
    position: relative;
    width: 100%;
    min-height: 560px;
    perspective: 2000px;
    transform-style: preserve-3d;
    z-index: 1;
  }

  .iso-stage {
    position: relative;
    width: 100%;
    min-height: 560px;
    transform-style: preserve-3d;
    transform: rotateX(var(--iso-tilt-x)) rotateY(0deg) rotateZ(var(--iso-tilt-z));
    transition: transform var(--iso-duration) cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .iso-layer {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    pointer-events: none; /* la capa misma no recibe eventos; sus hijos sí */
  }
  .iso-layer > * { pointer-events: auto; }

  .iso-l1 { transform: translateZ(var(--iso-elev));               z-index: 30; }
  .iso-l2 { transform: translateZ(0px);                           z-index: 20; }
  .iso-l3 { transform: translateZ(calc(var(--iso-elev) * -1));    z-index: 10; }

  /* ----------------------------------------
     Tarjetas (glass)
     ---------------------------------------- */
  .iso-card {
    background: var(--iso-glass);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border: 1px solid var(--iso-glass-border);
    border-radius: 16px;
    color: #fff;
    box-shadow:
      0 14px 28px -14px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .iso-tag {
    display: inline-block;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 6px;
  }
  .iso-tag-amber { color: var(--iso-amber-200); }

  /* ----------------------------------------
     Capa 1 — Roles + Coordinador
     ---------------------------------------- */
  .iso-roles-card {
    width: 100%;
    max-width: 560px;
    padding: 16px 20px 14px;
  }
  .iso-row {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: nowrap;
  }
  .iso-avatar {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a2740, #0d1b30);
    border: 1px solid var(--iso-glass-border);
    color: var(--iso-amber-200);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .iso-roles-text { flex: 1; min-width: 0; }
  .iso-roles-list {
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
    font-size: 13px;
    line-height: 1.3;
  }
  .iso-conn {
    color: var(--iso-amber-200);
    flex-shrink: 0;
    display: grid;
    place-items: center;
  }
  .iso-coord-card {
    background: linear-gradient(135deg, var(--iso-amber-400), var(--iso-amber-600));
    border-radius: 12px;
    padding: 10px 14px;
    color: #fff;
    text-align: center;
    flex-shrink: 0;
    box-shadow: 0 8px 18px -6px rgba(255, 122, 26, 0.45);
  }
  .iso-coord-name {
    font-weight: 700;
    font-size: 12px;
    line-height: 1.1;
    letter-spacing: 0.1px;
  }
  .iso-coord-sub {
    font-size: 9px;
    opacity: 0.92;
    margin-top: 2px;
  }
  .iso-desc {
    margin: 12px 0 0;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.45;
  }

  /* ----------------------------------------
     Capa 2 — Plataforma + agentes + hexágono
     ---------------------------------------- */
  .iso-platform {
    width: 100%;
    max-width: 600px;
    aspect-ratio: 3 / 2;
    position: relative;
    background: rgba(255, 246, 229, 0.06);
    border: 1.5px dashed rgba(255, 201, 122, 0.40);
    border-radius: 18px;
    padding: 18px;
  }
  .iso-platform-tag {
    position: absolute;
    top: -10px;
    left: 24px;
    background: var(--iso-bg-2);
    padding: 2px 12px;
    font-size: 9px;
    font-weight: 700;
    color: var(--iso-amber-200);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    border-radius: 6px;
  }
  .iso-platform-inner {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .iso-arrows {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .iso-agent {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 201, 122, 0.45);
    border-radius: 999px;
    padding: 5px 11px;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
    box-shadow:
      0 6px 14px -8px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: transform var(--iso-duration), background 200ms, border-color 200ms;
    color: #fff;
  }
  .iso-agent > svg { color: var(--iso-amber-200); }
  .iso-agent:hover {
    transform: translateY(-1px) scale(1.03);
    background: rgba(255, 255, 255, 0.12);
  }
  .iso-agent-hl {
    background: rgba(255, 122, 26, 0.22);
    border-color: var(--iso-amber-500);
    box-shadow:
      0 0 0 1px rgba(255, 122, 26, 0.5),
      0 0 24px rgba(255, 122, 26, 0.35);
  }
  .iso-agent-hl > svg { color: var(--iso-amber-200); }

  /* Posiciones de los 8 agentes alrededor del hexágono */
  .iso-agent-onboarder { top: 6%;  left: 6%;  }
  .iso-agent-scope     { top: 6%;  left: 50%; transform: translateX(-50%); }
  .iso-agent-schedule  { top: 6%;  right: 6%; }
  .iso-agent-repo      { top: 50%; left: 0%;  transform: translateY(-50%); }
  .iso-agent-evm       { top: 50%; right: 0%; transform: translateY(-50%); }
  .iso-agent-minutes   { bottom: 6%; left: 6%; }
  .iso-agent-risks     { bottom: 6%; left: 50%; transform: translateX(-50%); }
  .iso-agent-auditor   { bottom: 6%; right: 6%; }
  /* Pequeño contrapeso del transform para hover en agentes centrados */
  .iso-agent-scope:hover  { transform: translateX(-50%) translateY(-1px) scale(1.03); }
  .iso-agent-risks:hover  { transform: translateX(-50%) translateY(-1px) scale(1.03); }
  .iso-agent-repo:hover   { transform: translateY(-50%) scale(1.03); }
  .iso-agent-evm:hover    { transform: translateY(-50%) scale(1.03); }

  /* Hexágono central */
  .iso-hex {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 140px;
    height: 140px;
    padding: 1.5px;
    background: linear-gradient(135deg, var(--iso-amber-400), var(--iso-amber-600));
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    -webkit-clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    box-shadow:
      0 12px 32px -8px rgba(255, 122, 26, 0.45);
    z-index: 2;
  }
  .iso-hex-inner {
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, #FFE6B8 0%, #FFC97A 60%, #FFA63D 100%);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    -webkit-clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: grid;
    place-items: center;
    text-align: center;
    color: #0B1525;
  }
  .iso-hex-name {
    display: block;
    font-weight: 800;
    font-size: 13px;
    line-height: 1.15;
    padding: 0 12px;
  }
  .iso-hex-sub {
    display: block;
    font-size: 9px;
    font-weight: 600;
    color: #243044;
    margin-top: 3px;
  }

  /* ----------------------------------------
     Capa 3 — Dashboard + Artefactos
     ---------------------------------------- */
  .iso-l3-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    width: 100%;
    max-width: 600px;
  }
  .iso-dashboard, .iso-artifacts {
    padding: 14px 16px;
  }
  .iso-kpis {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .iso-kpi {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--iso-glass-border);
    border-radius: 10px;
    padding: 8px 6px;
    text-align: center;
  }
  .iso-kpi .k {
    display: block;
    font-size: 8px;
    font-weight: 700;
    color: var(--iso-amber-200);
    letter-spacing: 1px;
  }
  .iso-kpi .v {
    display: block;
    font-size: 17px;
    font-weight: 800;
    color: #fff;
    margin-top: 2px;
  }
  .iso-kpi .d {
    display: block;
    font-size: 8px;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 2px;
  }

  .iso-art-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }
  .iso-art {
    background: rgba(255, 246, 229, 0.08);
    border: 1px solid rgba(255, 201, 122, 0.30);
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 10.5px;
    font-weight: 600;
    color: #fff;
  }
  .iso-art-cta {
    background: linear-gradient(135deg, var(--iso-amber-500), var(--iso-amber-600));
    color: #fff;
    border-color: var(--iso-amber-500);
    font-weight: 700;
  }

  /* ============================================================
     RESPONSIVE — <1024px: desactivar iso, layout vertical
     ============================================================ */
  @media (max-width: 1023.98px) {
    .iso-wrap {
      padding: 22px 16px;
      min-height: 0;
    }
    .iso-scene { perspective: none; min-height: 0; }
    .iso-stage {
      transform: none;
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: 18px;
    }
    .iso-layer {
      position: relative;
      inset: auto;
      transform: none !important;
      z-index: auto;
    }
    .iso-layer > * { pointer-events: auto; }
    .iso-platform {
      aspect-ratio: auto;
      min-height: 420px;
      padding-top: 28px;
    }
    .iso-l3-grid { grid-template-columns: 1fr; }
  }

  /* En pantallas muy estrechas, agentes más pequeños y nombres más cortos visualmente */
  @media (max-width: 640px) {
    .iso-agent { font-size: 10px; padding: 4px 9px; gap: 5px; }
    .iso-hex { width: 110px; height: 110px; }
    .iso-hex-name { font-size: 11px; }
    .iso-row { flex-wrap: wrap; gap: 10px; }
    .iso-conn { display: none; }
    .iso-coord-card { width: 100%; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .iso-stage, .iso-agent { transition: none !important; }
  }
</style>
