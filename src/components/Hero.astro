---
import type { Lang } from '../data/content';
import { getContent, calendlyUrl } from '../data/content';
import MagneticButton from './MagneticButton.tsx';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).hero;
const g = t.graph;

// Posiciones de los 8 agentes en la "Capa operativa multiagente"
// Pill 120 x 30, distribución 3-2-3 alrededor del Tablero compartido (hex)
const agents = [
  // top row
  { name: g.agents.onboarder, x: 30,  y: 130, edge: { x: 150, y: 160 }, boardPt: { x: 252, y: 263 }, highlight: false },
  { name: g.agents.scope,     x: 240, y: 130, edge: { x: 300, y: 160 }, boardPt: { x: 300, y: 235 }, highlight: false },
  { name: g.agents.schedule,  x: 450, y: 130, edge: { x: 450, y: 160 }, boardPt: { x: 348, y: 263 }, highlight: false },
  // middle row (sides)
  { name: g.agents.repo,      x: 30,  y: 275, edge: { x: 150, y: 290 }, boardPt: { x: 245, y: 290 }, highlight: false },
  { name: g.agents.evm,       x: 450, y: 275, edge: { x: 450, y: 290 }, boardPt: { x: 355, y: 290 }, highlight: false },
  // bottom row
  { name: g.agents.risks,     x: 30,  y: 420, edge: { x: 150, y: 420 }, boardPt: { x: 252, y: 318 }, highlight: false },
  { name: g.agents.minutes,   x: 240, y: 420, edge: { x: 300, y: 420 }, boardPt: { x: 300, y: 345 }, highlight: false },
  { name: g.agents.auditor,   x: 450, y: 420, edge: { x: 450, y: 420 }, boardPt: { x: 348, y: 318 }, highlight: true  },
];
---

<section class="relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-5 pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-5">
        <span class="eyebrow">{t.eyebrow}</span>
        <h1 class="mt-4 text-4xl md:text-6xl font-bold leading-[1.05] text-ink-900">
          {t.title}
        </h1>
        <p class="mt-6 text-lg md:text-xl text-ink-700 max-w-2xl">
          {t.subtitle}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <MagneticButton client:load href="#waitlist" className="btn-primary">
            {t.ctaPrimary} →
          </MagneticButton>
          <MagneticButton client:load href={calendlyUrl} external strength={0.18} className="btn-ghost">
            {t.ctaSecondary}
          </MagneticButton>
        </div>
      </div>

      <!--
        Gráfica hero — v0.3.0 refinado
        ====================================================================
        Top zone: Persona profesional (busto con corbata) habla con el Agente
        Coordinador PMO; bocadillo con 2 oraciones explica el flujo.
        Frame "Capa operativa multiagente" (color de Capa de Supervisión de
        la sección Solución) envuelve los 8 agentes en pills con icono robot
        + nombre, conectados al Tablero compartido (hexágono central) con
        líneas punteadas y flechas bidireccionales (consultan y escriben).
        Bottom: Dashboard ejecutivo + Artefactos PMO alineados al ancho.
      -->
      <div class="md:col-span-7">
        <div class="relative aspect-[600/580] max-w-2xl mx-auto">
          <svg viewBox="0 0 600 580" class="w-full h-full" aria-hidden="true">
            <defs>
              <linearGradient id="hero-pill" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#FFE6B8"/>
                <stop offset="100%" stop-color="#FFC97A"/>
              </linearGradient>
              <marker id="arrEnd" viewBox="0 0 10 10" refX="9" refY="5"
                      markerWidth="6" markerHeight="6" orient="auto">
                <path d="M0 0 L10 5 L0 10 Z" fill="#E55F0A"/>
              </marker>
              <marker id="arrStart" viewBox="0 0 10 10" refX="1" refY="5"
                      markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                <path d="M0 0 L10 5 L0 10 Z" fill="#E55F0A"/>
              </marker>
            </defs>

            <!-- ========== TOP ZONE: Persona + Bocadillo + Coordinador ========== -->

            <!-- Persona B: busto profesional con corbata -->
            <g aria-label="Profesional (PM, Director PMO, CTO o CEO)">
              <circle cx="50" cy="35" r="13" fill="#fff" stroke="#243044" stroke-width="2.5"/>
              <path d="M 22 95 C 22 75, 36 65, 50 65 C 64 65, 78 75, 78 95"
                    fill="#fff" stroke="#243044" stroke-width="2.5" stroke-linejoin="round"/>
              <path d="M 46 65 L 50 80 L 54 65 Z" fill="#FF7A1A" stroke="#FF7A1A"/>
              <line x1="50" y1="80" x2="50" y2="92" stroke="#FF7A1A" stroke-width="2.8" stroke-linecap="round"/>
            </g>

            <!-- Bocadillo de la conversación -->
            <path d="M 100 18 L 410 18 Q 420 18 420 28 L 420 80 Q 420 90 410 90
                     L 122 90 L 96 96 L 108 90 L 100 90 Q 90 90 90 80 L 90 28 Q 90 18 100 18 Z"
                  fill="#fff" stroke="#CCD5E0" stroke-width="1.2"/>
            <text x="105" y="38" font-family="Inter" font-size="10" font-weight="600" fill="#243044">{g.pmBubbleLine1}</text>
            <text x="105" y="65" font-family="Inter" font-size="10" font-weight="500" fill="#56657A">{g.pmBubbleLine2}</text>

            <!-- Línea bidireccional bocadillo ↔ Coordinador -->
            <line x1="420" y1="50" x2="438" y2="50" stroke="#FF7A1A" stroke-width="1.8"
                  marker-end="url(#arrEnd)" marker-start="url(#arrStart)"/>

            <!-- Coordinador pill -->
            <rect x="438" y="30" width="148" height="44" rx="12"
                  fill="url(#hero-pill)" stroke="#B84507" stroke-width="1.5"/>
            <text x="512" y="51" text-anchor="middle" font-family="Inter"
                  font-size="11" font-weight="700" fill="#0B1525">{g.coordinator}</text>
            <text x="512" y="65" text-anchor="middle" font-family="Inter"
                  font-size="9" font-weight="500" fill="#243044">{g.coordinatorRole}</text>

            <!-- ========== FRAME: Capa operativa multiagente ========== -->
            <rect x="20" y="100" width="560" height="365" rx="18"
                  fill="#FFF6E5" stroke="#FFC97A" stroke-width="1.8" stroke-dasharray="6 4"/>
            <rect x="36" y="92" width="240" height="20" rx="10" fill="#fff" stroke="#FFC97A" stroke-width="1.2"/>
            <text x="156" y="106" text-anchor="middle" font-family="Inter"
                  font-size="10" font-weight="700" fill="#B84507" letter-spacing="1.5">
              {g.layerLabel.toUpperCase()}
            </text>

            <!-- Líneas punteadas bidireccionales: agente ↔ Tablero -->
            {agents.map((a) => (
              <line x1={a.edge.x} y1={a.edge.y} x2={a.boardPt.x} y2={a.boardPt.y}
                    stroke="#FFA63D" stroke-width="1.4" stroke-dasharray="3 3"
                    marker-start="url(#arrStart)" marker-end="url(#arrEnd)"/>
            ))}

            <!-- Tablero compartido (hexágono central) -->
            <polygon points="300,235 348,262 348,318 300,345 252,318 252,262"
                     fill="url(#hero-pill)" stroke="#B84507" stroke-width="2"/>
            <text x="300" y="280" text-anchor="middle" font-family="Inter"
                  font-size="11" font-weight="700" fill="#0B1525">{g.board.split(' ')[0]}</text>
            <text x="300" y="295" text-anchor="middle" font-family="Inter"
                  font-size="11" font-weight="700" fill="#0B1525">{g.board.split(' ')[1] || ''}</text>
            <text x="300" y="312" text-anchor="middle" font-family="Inter"
                  font-size="8" font-weight="500" fill="#243044">{g.boardSub}</text>

            <!-- 8 agentes: pill rectangular con icono Robot B + nombre -->
            {agents.map((a) => (
              <g>
                <rect x={a.x} y={a.y} width="120" height="30" rx="10"
                      fill={a.highlight ? '#FFE6B8' : '#fff'}
                      stroke={a.highlight ? '#E55F0A' : '#FFA63D'}
                      stroke-width={a.highlight ? '2' : '1.5'}/>
                {/* Robot B minimalista: cabeza rectangular, ojos rendija, conectores laterales */}
                <g transform={`translate(${a.x + 6} ${a.y + 7}) scale(0.667)`}>
                  <rect x="4" y="6" width="16" height="12" rx="2"
                        fill="none" stroke="#B84507" stroke-width="2.5"
                        stroke-linecap="round" stroke-linejoin="round"/>
                  <line x1="8"  y1="11" x2="10" y2="11" stroke="#B84507" stroke-width="3"  stroke-linecap="round"/>
                  <line x1="14" y1="11" x2="16" y2="11" stroke="#B84507" stroke-width="3"  stroke-linecap="round"/>
                  <line x1="9"  y1="15" x2="15" y2="15" stroke="#B84507" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="2"  y1="11" x2="4"  y2="11" stroke="#B84507" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="20" y1="11" x2="22" y2="11" stroke="#B84507" stroke-width="2.5" stroke-linecap="round"/>
                </g>
                <text x={a.x + 32} y={a.y + 20} font-family="Inter"
                      font-size="11" font-weight="700" fill="#0B1525">{a.name}</text>
              </g>
            ))}

            <!-- ========== BOTTOM ZONE: Dashboard + Artefactos ========== -->

            <!-- Dashboard ejecutivo (alineado con izquierda del frame) -->
            <rect x="20" y="480" width="270" height="92" rx="12" fill="#0B1525"/>
            <text x="32" y="500" font-family="Inter" font-size="9" font-weight="700"
                  fill="#FFC97A" letter-spacing="1">{g.dashboardLabel.toUpperCase()}</text>
            <rect x="32" y="508" width="76" height="54" rx="6" fill="#0d1b30" stroke="#243044"/>
            <text x="70" y="522" text-anchor="middle" fill="#FFC97A" font-size="8" font-family="Inter">CPI</text>
            <text x="70" y="546" text-anchor="middle" fill="#fff" font-size="15" font-weight="700" font-family="Inter">1.04</text>
            <rect x="116" y="508" width="76" height="54" rx="6" fill="#0d1b30" stroke="#243044"/>
            <text x="154" y="522" text-anchor="middle" fill="#FFC97A" font-size="8" font-family="Inter">SPI</text>
            <text x="154" y="546" text-anchor="middle" fill="#fff" font-size="15" font-weight="700" font-family="Inter">0.97</text>
            <rect x="200" y="508" width="80" height="54" rx="6" fill="#0d1b30" stroke="#243044"/>
            <text x="240" y="522" text-anchor="middle" fill="#FFC97A" font-size="8" font-family="Inter">EAC</text>
            <text x="240" y="546" text-anchor="middle" fill="#fff" font-size="13" font-weight="700" font-family="Inter">$1.2M</text>

            <!-- Artefactos PMO (alineados con derecha del frame) -->
            <rect x="310" y="480" width="270" height="92" rx="12"
                  fill="#fff" stroke="#FFC97A" stroke-dasharray="4 4"/>
            <text x="322" y="500" font-family="Inter" font-size="9" font-weight="700"
                  fill="#B84507" letter-spacing="1">{g.artifactsLabel.toUpperCase()}</text>
            <g font-family="Inter" font-size="9">
              <rect x="322" y="510" width="78" height="22" rx="5" fill="#FFF6E5" stroke="#FFC97A"/>
              <text x="361" y="525" text-anchor="middle" font-weight="700" fill="#243044">{g.artifacts.status}</text>
              <rect x="406" y="510" width="78" height="22" rx="5" fill="#FFF6E5" stroke="#FFC97A"/>
              <text x="445" y="525" text-anchor="middle" font-weight="700" fill="#243044">{g.artifacts.raid}</text>
              <rect x="490" y="510" width="80" height="22" rx="5" fill="#FFF6E5" stroke="#FFC97A"/>
              <text x="530" y="525" text-anchor="middle" font-weight="700" fill="#243044">{g.artifacts.minute}</text>
              <rect x="322" y="538" width="78" height="22" rx="5" fill="#FFF6E5" stroke="#FFC97A"/>
              <text x="361" y="553" text-anchor="middle" font-weight="700" fill="#243044">{g.artifacts.schedule}</text>
              <rect x="406" y="538" width="78" height="22" rx="5" fill="#FFF6E5" stroke="#FFC97A"/>
              <text x="445" y="553" text-anchor="middle" font-weight="700" fill="#243044">{g.artifacts.evm}</text>
              <rect x="490" y="538" width="80" height="22" rx="5" fill="#0B1525"/>
              <text x="530" y="553" text-anchor="middle" font-weight="700" fill="#FFC97A">{g.artifacts.committee}</text>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
