---
import type { Lang } from '../data/content';
import { getContent, calendlyUrl } from '../data/content';
import MagneticButton from './MagneticButton.tsx';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).hero;

// Imagen de arquitectura por idioma (servida desde /public)
const archImg = lang === 'en'
  ? '/hero-architecture-en.png'
  : '/hero-architecture-es.png';

const archAlt = lang === 'en'
  ? 'PMOforge — Intelligent Coordination Architecture: C-LEVEL roles, PM role, PMO Ecosystem UI, multi-agent operational layer with 8 agents around the PMO Coordinator Agent, and analytics data layer with Executive Dashboard, ROI and Learning'
  : 'PMOforge — Arquitectura de Coordinación Inteligente: roles C-LEVEL, rol PM, UI Ecosistema PMO, Capa Operativa Multiagente con 8 agentes alrededor del Agente Coordinador PMO, y Capa de Datos Analítica con Dashboard Ejecutivo, ROI y Aprendizaje';

// Bullets de balance (debajo del subtítulo) — recreados con copy existente
const bullets = lang === 'en'
  ? [
      'Roles like PM, PMO Director, CTO and CEO talk to a single PMO Coordinator Agent.',
      'Eight specialist agents work in parallel on a shared co-creation board.',
      'Live Executive Dashboard with SPI · CPI · EAC and risk score.',
      'Projected ROI plus continuous lessons and cross-project learning.'
    ]
  : [
      'Roles como PM, Director PMO, CTO y CEO conversan con un único Agente Coordinador PMO.',
      'Ocho agentes especialistas trabajan en paralelo sobre un tablero compartido de co-creación.',
      'Dashboard Ejecutivo en vivo con SPI · CPI · EAC y score de riesgos.',
      'ROI proyectado más lecciones continuas y aprendizaje cross-proyecto.'
    ];
---

<section class="relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-5 pt-3 pb-16 md:pt-4 md:pb-24">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-start">

      <!-- LEFT: copy con bullets para simetría en altura con la imagen -->
      <div class="lg:col-span-5">
        <span class="eyebrow">{t.eyebrow}</span>
        <h1 class="mt-4 text-4xl md:text-5xl xl:text-6xl font-bold leading-[1.05] text-ink-900">
          {t.title}
        </h1>
        <p class="mt-5 text-lg text-ink-700 max-w-xl">
          {t.subtitle}
        </p>

        <ul class="hero-bullets mt-6 space-y-2.5">
          {bullets.map((b) => (
            <li class="flex items-start gap-3 text-ink-700 leading-relaxed">
              <svg class="hero-bullet-icon mt-0.5 flex-shrink-0" viewBox="0 0 20 20"
                   width="20" height="20" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="10" cy="10" r="9"/>
                <path d="M6 10.2l2.8 2.8L14 8"/>
              </svg>
              <span>{b}</span>
            </li>
          ))}
        </ul>

        <div class="mt-8 flex flex-wrap gap-3">
          <MagneticButton client:load href="#waitlist" className="btn-primary">
            {t.ctaPrimary} →
          </MagneticButton>
          <MagneticButton client:load href={calendlyUrl} external strength={0.18} className="btn-ghost">
            {t.ctaSecondary}
          </MagneticButton>
        </div>
      </div>

      <!-- RIGHT: Imagen de arquitectura (ES o EN según idioma activo) -->
      <div class="lg:col-span-7">
        <figure class="hero-arch">
          <picture>
            {/* WebP optimizado (servido si el navegador lo soporta — ~70% más liviano) */}
            <source type="image/webp" srcset={archImg.replace('.png', '.webp')} />
            {/* PNG fuente como fallback universal */}
            <img
              src={archImg}
              alt={archAlt}
              width="1174"
              height="1339"
              loading="eager"
              decoding="async"
              fetchpriority="high"
              class="hero-arch-img"
            />
          </picture>
        </figure>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-bullets {
    font-size: 0.97rem;
  }
  .hero-bullet-icon {
    color: #FF7A1A; /* ember-500 */
  }

  .hero-arch {
    margin: 0;
    position: relative;
    width: 100%;
    border-radius: 22px;
    overflow: hidden;
    box-shadow:
      0 30px 60px -30px rgba(11, 21, 37, 0.25),
      0 0 0 1px rgba(255, 255, 255, 0.6) inset;
  }
  .hero-arch-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 22px;
    /* Asegura que la imagen no se corte por el overflow del padre */
    object-fit: contain;
  }

  /* Responsive */
  @media (max-width: 1023.98px) {
    .hero-arch {
      max-width: 720px;
      margin: 0 auto;
    }
  }

  /* Reduced motion: nothing animated en hero, no-op aquí */
</style>
