---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).solution;

// Estilos por capa con clases ESTÁTICAS — Tailwind las detecta sin problemas
const layerStyles = [
  // Capa 1 — Mando (PMP humano): fondo oscuro, alto contraste, glow-border
  {
    article: 'glow-border rounded-2xl border-2 p-6 shadow-sm transition bg-ink-900 text-white border-ink-900',
    badge: 'inline-grid place-items-center w-9 h-9 rounded-full text-sm font-bold bg-ember-500 text-white',
    title: 'font-serif font-bold text-xl text-white',
    role: 'text-sm text-ember-200 font-semibold',
    desc: 'mt-3 leading-relaxed text-white'
  },
  // Capa 2 — Supervisión: fondo crema/ámbar
  {
    article: 'rounded-2xl border-2 p-6 shadow-sm transition bg-ember-50 border-ember-300 text-ink-900',
    badge: 'inline-grid place-items-center w-9 h-9 rounded-full text-sm font-bold bg-ink-900 text-white',
    title: 'font-serif font-bold text-xl text-ink-900',
    role: 'text-sm text-ember-700 font-semibold',
    desc: 'mt-3 leading-relaxed text-ink-700'
  },
  // Capa 3 — Operativos: tarjeta blanca con borde sólido
  {
    article: 'rounded-2xl border-2 p-6 shadow-sm transition bg-white border-ink-200 text-ink-900',
    badge: 'inline-grid place-items-center w-9 h-9 rounded-full text-sm font-bold bg-ink-900 text-white',
    title: 'font-serif font-bold text-xl text-ink-900',
    role: 'text-sm text-ember-700 font-semibold',
    desc: 'mt-3 leading-relaxed text-ink-700'
  }
];
---

<section id="solution" class="relative">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 max-w-3xl leading-tight">
      {t.title}
    </h2>
    <p class="mt-5 text-lg text-ink-700 max-w-3xl leading-relaxed">{t.intro}</p>

    <!-- Pirámide de capas -->
    <div class="mt-12 grid gap-4">
      {t.layers.map((layer, i) => {
        const s = layerStyles[i];
        return (
          <article class={s.article}>
            <div class="flex items-center gap-3">
              <span class={s.badge}>{i + 1}</span>
              <div>
                <h3 class={s.title}>{layer.name}</h3>
                <p class={s.role}>{layer.role}</p>
              </div>
            </div>
            <p class={s.desc}>{layer.description}</p>
          </article>
        );
      })}
    </div>

    <!-- Banda de gobierno -->
    <div class="mt-10 rounded-2xl border-2 border-dashed border-ember-300 bg-ember-50/50 p-6">
      <h3 class="font-serif font-bold text-xl text-ink-900">{t.governance.title}</h3>
      <p class="mt-2 text-ink-700 leading-relaxed">{t.governance.body}</p>
    </div>
  </div>
</section>
