---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).solution;

// Estilos por capa con clases ESTÁTICAS — Tailwind las detecta sin problemas
const layerStyles = [
  // Capa 1 — Mando (PMP humano): panel destacado con halo ember (glow-border)
  {
    article: 'glow-border rounded-2xl border border-ember-500/40 p-6 shadow-lg shadow-ember-500/10 transition bg-forge-panel2 text-paper',
    badge: 'inline-grid place-items-center w-9 h-9 rounded-full text-sm font-bold bg-ember-500 text-white',
    title: 'font-serif font-bold text-xl text-cream',
    role: 'text-sm text-ember-200 font-semibold',
    desc: 'mt-3 leading-relaxed text-paper'
  },
  // Capa 2 — Supervisión: panel con tinte ember
  {
    article: 'rounded-2xl border p-6 shadow-sm transition bg-ember-500/10 border-ember-500/30 text-paper',
    badge: 'inline-grid place-items-center w-9 h-9 rounded-full text-sm font-bold bg-ember-500 text-white',
    title: 'font-serif font-bold text-xl text-cream',
    role: 'text-sm text-ember-200 font-semibold',
    desc: 'mt-3 leading-relaxed text-mute'
  },
  // Capa 3 — Operativos: panel oscuro plano
  {
    article: 'rounded-2xl border p-6 shadow-sm transition bg-forge-panel border-white/10 text-paper',
    badge: 'inline-grid place-items-center w-9 h-9 rounded-full text-sm font-bold bg-white/10 text-cream',
    title: 'font-serif font-bold text-xl text-cream',
    role: 'text-sm text-ember-200 font-semibold',
    desc: 'mt-3 leading-relaxed text-mute'
  }
];
---

<section id="solution" class="relative">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-cream max-w-3xl leading-tight">
      {t.title}
    </h2>
    <p class="mt-5 text-lg text-mute max-w-3xl leading-relaxed">{t.intro}</p>

    <!-- Pirámide de capas -->
    <div class="mt-12 grid gap-4">
      {t.layers.map((layer, i) => {
        const s = layerStyles[i];
        return (
          <article class={s.article}>
            <div class="flex items-center gap-3">
              <span class={s.badge}>{i + 1}</span>
              <div>
                <h3 class={s.title}>{layer.name}</h3>
                <p class={s.role}>{layer.role}</p>
              </div>
            </div>
            <p class={s.desc}>{layer.description}</p>
          </article>
        );
      })}
    </div>

    <!-- Banda de gobierno -->
    <div class="mt-10 rounded-2xl border-2 border-dashed border-ember-500/30 bg-ember-500/5 p-6">
      <h3 class="font-serif font-bold text-xl text-cream">{t.governance.title}</h3>
      <p class="mt-2 text-mute leading-relaxed">{t.governance.body}</p>
    </div>
  </div>
</section>
