---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).solution;
---

<section id="solution" class="relative">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 max-w-3xl leading-tight">
      {t.title}
    </h2>
    <p class="mt-5 text-lg text-ink-700 max-w-3xl leading-relaxed">{t.intro}</p>

    <!-- Pirámide de capas -->
    <div class="mt-12 grid gap-4">
      {t.layers.map((layer, i) => (
        <article class={`card relative ${i === 0 ? 'bg-ink-900 text-white border-ink-900' : i === 1 ? 'bg-ember-50 border-ember-200' : ''}`}>
          <div class="flex items-center gap-3">
            <span class={`inline-grid place-items-center w-8 h-8 rounded-full text-sm font-bold ${i === 0 ? 'bg-ember-500 text-white' : 'bg-ink-900 text-white'}`}>
              {i + 1}
            </span>
            <div>
              <h3 class={`font-serif font-bold text-xl ${i === 0 ? 'text-white' : 'text-ink-900'}`}>{layer.name}</h3>
              <p class={`text-sm ${i === 0 ? 'text-ember-200' : 'text-ember-700'} font-semibold`}>{layer.role}</p>
            </div>
          </div>
          <p class={`mt-3 leading-relaxed ${i === 0 ? 'text-ink-100' : 'text-ink-700'}`}>{layer.description}</p>
        </article>
      ))}
    </div>

    <!-- Banda de gobierno -->
    <div class="mt-10 rounded-2xl border-2 border-dashed border-ember-300 bg-ember-50/50 p-6">
      <h3 class="font-serif font-bold text-xl text-ink-900">{t.governance.title}</h3>
      <p class="mt-2 text-ink-700 leading-relaxed">{t.governance.body}</p>
    </div>
  </div>
</section>
