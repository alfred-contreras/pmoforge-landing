---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang);
const altLang: Lang = lang === 'es' ? 'en' : 'es';
const altHref = altLang === 'en' ? '/en/' : '/';
---

<header class="sticky top-0 z-40 backdrop-blur bg-white/70 border-b border-ink-100">
  <nav class="max-w-7xl mx-auto px-5 py-3 flex items-center justify-between gap-4">
    <a href={lang === 'en' ? '/en/' : '/'} class="flex items-center gap-2 font-serif font-bold text-lg text-ink-900 shrink-0 whitespace-nowrap">
      <span class="inline-block w-7 h-7 rounded-md bg-gradient-to-br from-ember-500 to-ember-700 grid place-items-center text-white text-sm">⚒</span>
      PMOforge
    </a>
    <ul class="hidden md:flex items-center gap-x-5 lg:gap-x-6 text-sm text-ink-700 flex-nowrap">
      <li class="hidden lg:block"><a href="#problem" class="hover:text-ember-600 whitespace-nowrap">{t.nav.problem}</a></li>
      <li><a href="#solution" class="hover:text-ember-600 whitespace-nowrap">{t.nav.solution}</a></li>
      <li><a href="#competitive" class="hover:text-ember-600 whitespace-nowrap">{t.nav.competitive}</a></li>
      <li><a href="#security" class="hover:text-ember-600 whitespace-nowrap">{t.nav.security}</a></li>
      <li><a href="#vision" class="hover:text-ember-600 whitespace-nowrap">{t.nav.vision}</a></li>
      <li class="hidden xl:block"><a href="#value" class="hover:text-ember-600 whitespace-nowrap">{t.nav.value}</a></li>
      <li class="hidden xl:block"><a href="#use-cases" class="hover:text-ember-600 whitespace-nowrap">{t.nav.useCases}</a></li>
      <li class="hidden 2xl:block"><a href="#preview" class="hover:text-ember-600 whitespace-nowrap">{t.nav.preview}</a></li>
      <li class="hidden xl:block"><a href="#founder" class="hover:text-ember-600 whitespace-nowrap">{t.nav.founder}</a></li>
    </ul>
    <div class="flex items-center gap-2 shrink-0">
      <a href={altHref}
         class="text-xs font-semibold uppercase rounded-md border border-ink-200 px-2 py-1 text-ink-700 hover:bg-ink-50">
        {altLang.toUpperCase()}
      </a>
      <a href="#waitlist" class="btn-primary text-sm py-2 px-4 whitespace-nowrap">{t.nav.waitlist}</a>
    </div>
  </nav>
</header>
