---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).audience;
---

<section id="audience" class="forge-section-alt border-y border-white/10">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-cream max-w-3xl leading-tight">
      {t.title}
    </h2>
    <p class="mt-5 text-lg text-mute max-w-3xl leading-relaxed">{t.lead}</p>

    <div class="mt-12 grid md:grid-cols-2 gap-5">
      {t.columns.map((col, i) => (
        <article class={i === 0 ? 'card border-2 border-ember-500/30 bg-ember-500/10' : 'card border-2 border-white/10 bg-white/5'}>
          <div class="flex items-center gap-3 mb-4">
            <span class={i === 0
              ? 'inline-grid place-items-center w-10 h-10 rounded-full bg-ember-500 text-[#150a00] font-bold'
              : 'inline-grid place-items-center w-10 h-10 rounded-full bg-white/10 text-ember-200 font-bold'}>
              {i === 0 ? 'PM' : 'C'}
            </span>
            <div>
              <h3 class="font-serif font-bold text-xl text-cream">{col.label}</h3>
              <p class="text-sm text-mute">{col.sub}</p>
            </div>
          </div>
          <ul class="space-y-3">
            {col.items.map((it) => (
              <li class="flex gap-3">
                <span class={i === 0 ? 'inline-block w-1.5 h-1.5 mt-2.5 rounded-full bg-ember-500 flex-shrink-0' : 'inline-block w-1.5 h-1.5 mt-2.5 rounded-full bg-mute flex-shrink-0'}></span>
                <span>
                  <span class="font-semibold text-paper">{it.k}</span>
                  <span class="text-mute"> — {it.v}</span>
                </span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <p class="mt-10 max-w-3xl text-mute leading-relaxed italic border-l-2 border-ember-500 pl-4">
      {t.closer}
    </p>
  </div>
</section>
