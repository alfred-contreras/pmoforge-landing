---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).audience;
---

<section id="audience" class="bg-white border-y border-ink-100">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 max-w-3xl leading-tight">
      {t.title}
    </h2>
    <p class="mt-5 text-lg text-ink-700 max-w-3xl leading-relaxed">{t.lead}</p>

    <div class="mt-12 grid md:grid-cols-2 gap-5">
      {t.columns.map((col, i) => (
        <article class={i === 0 ? 'card border-2 border-ember-200 bg-ember-50/40' : 'card border-2 border-ink-200 bg-ink-50/50'}>
          <div class="flex items-center gap-3 mb-4">
            <span class={i === 0
              ? 'inline-grid place-items-center w-10 h-10 rounded-full bg-ember-500 text-white font-bold'
              : 'inline-grid place-items-center w-10 h-10 rounded-full bg-ink-900 text-ember-200 font-bold'}>
              {i === 0 ? 'PM' : 'C'}
            </span>
            <div>
              <h3 class="font-serif font-bold text-xl text-ink-900">{col.label}</h3>
              <p class="text-sm text-ink-500">{col.sub}</p>
            </div>
          </div>
          <ul class="space-y-3">
            {col.items.map((it) => (
              <li class="flex gap-3">
                <span class={i === 0 ? 'inline-block w-1.5 h-1.5 mt-2.5 rounded-full bg-ember-500 flex-shrink-0' : 'inline-block w-1.5 h-1.5 mt-2.5 rounded-full bg-ink-700 flex-shrink-0'}></span>
                <span>
                  <span class="font-semibold text-ink-900">{it.k}</span>
                  <span class="text-ink-700"> — {it.v}</span>
                </span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <p class="mt-10 max-w-3xl text-ink-700 leading-relaxed italic border-l-2 border-ember-500 pl-4">
      {t.closer}
    </p>
  </div>
</section>
