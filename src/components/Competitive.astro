---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).competitive;
---

<section id="competitive" class="bg-white border-y border-ink-100">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 max-w-3xl leading-tight">
      {t.title}
    </h2>
    <p class="mt-5 text-lg text-ink-700 max-w-3xl leading-relaxed">{t.lead}</p>

    <!-- Tabla en desktop, lista de cards en mobile -->
    <div class="mt-10 hidden md:block overflow-x-auto rounded-2xl border border-ink-100 shadow-sm">
      <table class="w-full text-sm text-left">
        <thead>
          <tr class="bg-ink-50 text-ink-900">
            <th class="px-4 py-3 font-serif font-bold border-b border-ink-100">Eje</th>
            {t.columns.map((col, i) => (
              <th
                class={
                  i === 0
                    ? 'px-4 py-3 font-serif font-bold bg-ember-500 text-white border-b border-ember-500'
                    : 'px-4 py-3 font-serif font-bold border-b border-ink-100'
                }
              >
                {col}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {t.rows.map((row, ri) => (
            <tr class={ri % 2 === 0 ? 'bg-white' : 'bg-ink-50/50'}>
              <td class="px-4 py-3 font-semibold text-ink-900 border-b border-ink-100 align-top">
                {row.axis}
              </td>
              {row.values.map((val, ci) => (
                <td
                  class={
                    ci === 0
                      ? 'px-4 py-3 text-ink-900 bg-ember-50 border-b border-ink-100 align-top font-medium'
                      : 'px-4 py-3 text-ink-700 border-b border-ink-100 align-top'
                  }
                >
                  {val}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Mobile: una card por competidor -->
    <div class="mt-10 grid md:hidden gap-5">
      {t.columns.map((col, ci) => (
        <article class={ci === 0 ? 'card border-ember-500 border-2' : 'card'}>
          <h3 class="font-serif font-bold text-lg text-ink-900">{col}</h3>
          <ul class="mt-3 space-y-3 text-sm">
            {t.rows.map((row) => (
              <li>
                <span class="block text-xs font-semibold uppercase tracking-wider text-ember-700">
                  {row.axis}
                </span>
                <span class={ci === 0 ? 'text-ink-900 font-medium' : 'text-ink-700'}>
                  {row.values[ci]}
                </span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <p class="mt-6 text-xs text-ink-500 leading-relaxed max-w-3xl">{t.note}</p>

    {t.ppm && (
      <article class="mt-10 rounded-2xl border border-ink-100 bg-ink-50/60 p-6 md:p-8 max-w-4xl">
        <h3 class="font-serif font-bold text-xl text-ink-900 leading-snug">
          {t.ppm.title}
        </h3>
        <p class="mt-3 text-ink-700 leading-relaxed">{t.ppm.body}</p>
        <p class="mt-3 text-ink-700 leading-relaxed text-sm italic border-l-2 border-ember-500 pl-4">
          {t.ppm.adjacent}
        </p>
      </article>
    )}
  </div>
</section>
