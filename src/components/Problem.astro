---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).problem;
---

<section id="problem" class="bg-white border-y border-ink-100">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 max-w-3xl leading-tight">
      {t.title}
    </h2>

    <div class="mt-12 grid md:grid-cols-2 gap-5">
      {t.bullets.map((b) => (
        <article class="card">
          <h3 class="font-serif font-bold text-xl text-ink-900">{b.title}</h3>
          <p class="mt-2 text-ink-700 leading-relaxed">{b.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
