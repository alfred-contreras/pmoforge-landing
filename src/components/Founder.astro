---
import type { Lang } from '../data/content';
import { getContent } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).founder;
---

<section id="founder">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <div class="grid md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-7">
        <span class="eyebrow">{t.eyebrow}</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 leading-tight">
          {t.title}
        </h2>
        <p class="mt-5 text-lg text-ink-700 leading-relaxed">{t.body}</p>
        <a href={t.cvUrl} target="_blank" rel="noopener" class="mt-6 inline-flex items-center gap-2 font-semibold text-ember-600 hover:text-ember-700">
          {t.cvLink} →
        </a>
      </div>
      <aside class="md:col-span-5 card bg-gradient-to-br from-ember-50 to-white">
        <ul class="space-y-3 text-ink-700">
          <li class="flex items-start gap-3">
            <span class="mt-1 inline-block w-2 h-2 rounded-full bg-ember-500"></span>
            <span><strong class="text-ink-900">PMP®</strong> {lang === 'en' ? 'since' : 'desde'} 2010</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 inline-block w-2 h-2 rounded-full bg-ember-500"></span>
            <span><strong class="text-ink-900">MBA</strong></span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 inline-block w-2 h-2 rounded-full bg-ember-500"></span>
            <span><strong class="text-ink-900">MIT xPRO</strong> — AI Product Design</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 inline-block w-2 h-2 rounded-full bg-ember-500"></span>
            <span>24+ {lang === 'en' ? 'years engineering' : 'años en ingeniería'}, 14+ {lang === 'en' ? 'years leading delivery' : 'liderando entregas'}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 inline-block w-2 h-2 rounded-full bg-ember-500"></span>
            <span>{lang === 'en' ? 'USD 10M+ annual budgets' : 'Presupuestos > USD 10M anuales'}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 inline-block w-2 h-2 rounded-full bg-ember-500"></span>
            <span>Telco · Oil & Gas · {lang === 'en' ? 'Government' : 'Gobierno'}</span>
          </li>
        </ul>
      </aside>
    </div>
  </div>
</section>
