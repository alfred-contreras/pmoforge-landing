---
import type { Lang } from '../data/content';
import { getContent, calendlyUrl } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).security;
---

<section id="security" class="bg-white border-y border-ink-100">
  <div class="max-w-6xl mx-auto px-5 py-20">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold text-ink-900 max-w-3xl leading-tight">
      {t.title}
    </h2>
    <p class="mt-5 text-lg text-ink-700 max-w-3xl leading-relaxed">{t.lead}</p>

    <div class="mt-12 grid md:grid-cols-2 gap-5">
      {t.pillars.map((pillar, i) => (
        <article class="card flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <span
              class="inline-grid place-items-center w-12 h-12 rounded-xl bg-ink-900 text-ember-200 shadow-sm"
              aria-hidden="true"
            >
              {i === 0 && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              )}
              {i === 1 && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="4 4 20 4 20 8 4 8"/>
                  <polyline points="6 8 18 8 18 12 6 12"/>
                  <polyline points="8 12 16 12 16 16 8 16"/>
                  <polyline points="10 16 14 16 14 20 10 20"/>
                </svg>
              )}
              {i === 2 && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="9"/>
                  <line x1="5" y1="5" x2="19" y2="19"/>
                  <path d="M8 12h8"/>
                </svg>
              )}
              {i === 3 && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="7" height="7" rx="1"/>
                  <rect x="14" y="3" width="7" height="7" rx="1"/>
                  <rect x="3" y="14" width="7" height="7" rx="1"/>
                  <rect x="14" y="14" width="7" height="7" rx="1"/>
                </svg>
              )}
              {i === 4 && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="8" y1="13" x2="16" y2="13"/>
                  <line x1="8" y1="17" x2="16" y2="17"/>
                </svg>
              )}
            </span>
          </div>
          <h3 class="font-serif font-bold text-xl text-ink-900 leading-snug">
            {pillar.title}
          </h3>
          <p class="text-ink-700 leading-relaxed">{pillar.body}</p>
        </article>
      ))}
    </div>

    <div class="mt-12 flex flex-col md:flex-row md:items-center md:justify-between gap-5 max-w-4xl">
      <p class="text-ink-900 font-medium leading-relaxed">{t.closer}</p>
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-sm py-2.5 px-5 whitespace-nowrap shrink-0"
      >
        {t.cta} →
      </a>
    </div>

    <p class="mt-6 text-xs text-ink-500 leading-relaxed max-w-3xl">{t.note}</p>
  </div>
</section>
