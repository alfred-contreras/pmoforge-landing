---
import type { Lang } from '../data/content';
import { getContent, calendlyUrl } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).waitlist;
const subject = lang === 'en' ? 'PMOforge — early access' : 'PMOforge — acceso anticipado';

// Formspree endpoint (proyecto "PMOforge Waitlist"). Plan TRIAL — ver D-23 en landing-roadmap.md
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/mzdqbaoz';
---

<section id="waitlist" class="bg-ink-900 text-white">
  <div class="max-w-3xl mx-auto px-5 py-20 text-center">
    <span class="inline-block rounded-full bg-ember-500/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-ember-200">
      {t.eyebrow}
    </span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold leading-tight">{t.title}</h2>
    <p class="mt-4 text-lg text-ink-100 leading-relaxed">{t.subtitle}</p>

    <!-- Form (Formspree AJAX — sin redirect a thank-you page) -->
    <form
      id="waitlist-form"
      action={FORMSPREE_ENDPOINT}
      method="POST"
      data-error-msg={t.errorMsg}
      class="mt-8 grid gap-3 max-w-lg mx-auto text-left"
    >
      <input type="hidden" name="_subject" value={subject} />
      <input type="hidden" name="_language" value={lang === 'en' ? 'en' : 'es'} />
      <!-- Honeypot anti-spam: bots completan campos ocultos, humanos no -->
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;pointer-events:none" aria-hidden="true" />

      <input type="text" name="name" required placeholder={t.namePlaceholder}
        class="rounded-xl bg-white/5 border border-white/15 px-4 py-3 text-white placeholder:text-ink-300 focus:outline-none focus:border-ember-400" />
      <input type="email" name="email" required placeholder={t.emailPlaceholder}
        class="rounded-xl bg-white/5 border border-white/15 px-4 py-3 text-white placeholder:text-ink-300 focus:outline-none focus:border-ember-400" />
      <input type="text" name="role" placeholder={t.rolePlaceholder}
        class="rounded-xl bg-white/5 border border-white/15 px-4 py-3 text-white placeholder:text-ink-300 focus:outline-none focus:border-ember-400" />
      <button type="submit" id="waitlist-submit" class="btn-primary justify-center mt-2 disabled:opacity-60 disabled:cursor-not-allowed">
        <span data-state="idle">{t.cta} →</span>
        <span data-state="sending" class="hidden">{t.sending}</span>
      </button>
      <p class="text-xs text-ink-300 text-center">{t.privacy}</p>
    </form>

    <!-- Success state -->
    <div id="waitlist-success" class="hidden mt-8 mx-auto max-w-lg rounded-xl border border-ember-400/40 bg-ember-500/10 px-6 py-5 text-center" role="status" aria-live="polite">
      <p class="font-semibold text-ember-200">{t.successTitle}</p>
      <p class="mt-1 text-sm text-ink-100">{t.successBody}</p>
    </div>

    <!-- Error state -->
    <div id="waitlist-error" class="hidden mt-6 mx-auto max-w-lg rounded-xl border border-red-400/40 bg-red-500/10 px-5 py-3 text-sm text-red-100" role="alert" aria-live="assertive"></div>

    <div class="mt-8 text-ink-200">
      <p class="text-sm">{t.or}</p>
      <a href={calendlyUrl} target="_blank" rel="noopener"
         class="mt-3 inline-flex items-center gap-2 font-semibold text-ember-200 hover:text-ember-400">
        📅 {t.bookCall}
      </a>
    </div>
  </div>
</section>

<script>
  // Formspree AJAX submit — mantiene al usuario en la página
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const successEl = document.getElementById('waitlist-success');
  const errorEl = document.getElementById('waitlist-error');
  const submitBtn = document.getElementById('waitlist-submit') as HTMLButtonElement | null;
  const idleLabel = submitBtn?.querySelector('[data-state="idle"]') as HTMLElement | null;
  const sendingLabel = submitBtn?.querySelector('[data-state="sending"]') as HTMLElement | null;

  function setSending(on: boolean) {
    if (!submitBtn || !idleLabel || !sendingLabel) return;
    submitBtn.disabled = on;
    idleLabel.classList.toggle('hidden', on);
    sendingLabel.classList.toggle('hidden', !on);
  }

  function showError(msg: string) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }

  function hideError() {
    errorEl?.classList.add('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();
    setSending(true);

    const fallbackError = form.dataset.errorMsg || 'Something went wrong.';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' }
      });

      if (res.ok) {
        form.classList.add('hidden');
        successEl?.classList.remove('hidden');
        successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        const data = await res.json().catch(() => null);
        const msg = data?.errors?.[0]?.message || fallbackError;
        showError(msg);
        setSending(false);
      }
    } catch (_err) {
      showError(fallbackError);
      setSending(false);
    }
  });
</script>
