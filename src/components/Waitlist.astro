---
import type { Lang } from '../data/content';
import { getContent, calendlyUrl, contactEmail } from '../data/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = getContent(lang).waitlist;
const subject = encodeURIComponent(lang === 'en' ? 'PMOforge — early access' : 'PMOforge — acceso anticipado');
const mailtoHref = `mailto:${contactEmail}?subject=${subject}`;
---

<section id="waitlist" class="bg-ink-900 text-white">
  <div class="max-w-3xl mx-auto px-5 py-20 text-center">
    <span class="inline-block rounded-full bg-ember-500/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-ember-200">
      {t.eyebrow}
    </span>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold leading-tight">{t.title}</h2>
    <p class="mt-4 text-lg text-ink-100 leading-relaxed">{t.subtitle}</p>

    <!-- Form (mailto fallback hasta tener backend) -->
    <form
      action={mailtoHref}
      method="post"
      enctype="text/plain"
      class="mt-8 grid gap-3 max-w-lg mx-auto text-left"
    >
      <input type="text" name="name" required placeholder={t.namePlaceholder}
        class="rounded-xl bg-white/5 border border-white/15 px-4 py-3 text-white placeholder:text-ink-300 focus:outline-none focus:border-ember-400" />
      <input type="email" name="email" required placeholder={t.emailPlaceholder}
        class="rounded-xl bg-white/5 border border-white/15 px-4 py-3 text-white placeholder:text-ink-300 focus:outline-none focus:border-ember-400" />
      <input type="text" name="role" placeholder={t.rolePlaceholder}
        class="rounded-xl bg-white/5 border border-white/15 px-4 py-3 text-white placeholder:text-ink-300 focus:outline-none focus:border-ember-400" />
      <button type="submit" class="btn-primary justify-center mt-2">{t.cta} →</button>
      <p class="text-xs text-ink-300 text-center">{t.privacy}</p>
    </form>

    <div class="mt-8 text-ink-200">
      <p class="text-sm">{t.or}</p>
      <a href={calendlyUrl} target="_blank" rel="noopener"
         class="mt-3 inline-flex items-center gap-2 font-semibold text-ember-300 hover:text-ember-200">
        📅 {t.bookCall}
      </a>
    </div>
  </div>
</section>
